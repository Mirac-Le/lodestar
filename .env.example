# --- LLM & Embedding (OpenAI-compatible) ---
# Works with 阿里云百炼 (DashScope) / OpenAI / DeepSeek / Zhipu / Kimi / etc.

# ========== 推荐：阿里云百炼（中文场景最佳） ==========
# 到 https://bailian.console.aliyun.com/?apiKey=1 获取 API Key
LODESTAR_LLM_API_KEY=sk-xxxx
LODESTAR_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LODESTAR_LLM_MODEL=qwen-plus
# 可选：qwen-turbo(便宜快) / qwen-plus(均衡) / qwen-max(最强) / qwen3-*

LODESTAR_EMBEDDING_API_KEY=sk-xxxx
LODESTAR_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LODESTAR_EMBEDDING_MODEL=text-embedding-v4
LODESTAR_EMBEDDING_DIM=1024
# v4 单次最多 10 条，已自动分批；若换 v2 可以调大到 25
LODESTAR_EMBEDDING_BATCH_SIZE=10

# ========== 备选：OpenAI ==========
# LODESTAR_LLM_BASE_URL=https://api.openai.com/v1
# LODESTAR_LLM_MODEL=gpt-4o-mini
# LODESTAR_EMBEDDING_BASE_URL=https://api.openai.com/v1
# LODESTAR_EMBEDDING_MODEL=text-embedding-3-small
# LODESTAR_EMBEDDING_DIM=1536
# LODESTAR_EMBEDDING_BATCH_SIZE=2048

# ========== 备选：DeepSeek（仅 chat，无 embedding） ==========
# LODESTAR_LLM_BASE_URL=https://api.deepseek.com/v1
# LODESTAR_LLM_MODEL=deepseek-chat

# --- Storage ---
# Path to the SQLite database file. Defaults to XDG data dir.
# LODESTAR_DB_PATH=/path/to/lodestar.db

# --- Search tuning ---
# Max hop count when searching paths (default 3)
LODESTAR_MAX_HOPS=3
# Top-K candidate persons to return per search (default 10)
LODESTAR_TOP_K=10

# --- Stage-2 reranker ---
# 三档可选：none / llm / bge
# none = 不重排（零额外开销 / 零依赖）；新装默认值，不会动主链路
# llm  = 多调一次 LLM 把候选分成 本人/桥梁/无关，治理 bi-encoder 的"角色断崖"
#         代价：每次搜索多一次 chat completion 调用（~20s/q + token 费）
# bge  = 本地 cross-encoder BAAI/bge-reranker-v2-m3
#         代价：`uv sync --extra rerank` 装 torch CPU (~200MB) + 模型 (~560MB)
#         国内拉模型必须同时 export HF_ENDPOINT=https://hf-mirror.com
#                               export HF_HUB_DISABLE_XET=1
#         （hf-mirror 不代理 HF 1.x 的 Xet CDN，不关 Xet 大文件 chunk 仍会回源超时）
#
# 👉 推荐：装好 [rerank] extra 后改成 bge——质量与 llm 基本打平
#    (R@5 0.766 vs 0.769, NDCG@10 0.753 vs 0.782)，
#    cliff-avoid 反超 (0.85 vs 0.80)，延迟低 4 倍（~12s vs ~45s/q），零 token 费。
#    详细对照见 docs/eval_2026-04-21.md。
#
# ⚠️ 直接把默认值改成 bge 但又没装 [rerank] extra 时，会静默 fallback 到 noop，
#    跑出来跟 none 完全一样——所以本文件保留 none 作为 safe default。
LODESTAR_RERANKER=none
# 召回宽度——比 TOP_K 大才有意义（用更宽召回换重排精度）
LODESTAR_RERANKER_RECALL_K=30
